{
  "name": "Carex Protanopia Friendly",
  "include": "./carex-dark.json",
  "type": "dark",
  "colors": {
    "editor.background": "#12141d",
    "editor.foreground": "#ecf1ff",
    "editor.lineHighlightBackground": "#1f2433",
    "editor.selectionBackground": "#44537d66",
    "editorCursor.foreground": "#ffd97d",
    "editorLineNumber.foreground": "#7d8597",
    "editorLineNumber.activeForeground": "#7ad7f0",
    "activityBar.background": "#0c1018",
    "sideBar.background": "#0c1018",
    "statusBar.background": "#0c1018",
    "panel.background": "#0c1018",
    "terminal.background": "#0c1018",
    "focusBorder": "#7ad7f0"
  },
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "class": "#d4a5ff",
    "function": "#7ad7f0",
    "parameter": "#ffb86b",
    "property": "#8be9fd",
    "variable.readonly": "#ffd97d"
  },
  "tokenColors": [
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#8088a0", "fontStyle": "italic" }
    },
    {
      "name": "String",
      "scope": ["string"],
      "settings": { "foreground": "#8be9fd" }
    },
    {
      "name": "Keyword",
      "scope": ["keyword", "storage.type", "storage.modifier"],
      "settings": { "foreground": "#ffb86b" }
    },
    {
      "name": "Class",
      "scope": ["entity.name.class", "entity.name.type", "support.class"],
      "settings": { "foreground": "#d4a5ff" }
    }
  ]
}