{
  "name": "Carex High Contrast Light",
  "include": "./carex-light.json",
  "type": "light",
  "colors": {
    "editor.background": "#ffffff",
    "editor.foreground": "#111111",
    "editor.lineHighlightBackground": "#f0f0f0",
    "editor.selectionBackground": "#00000020",
    "editorCursor.foreground": "#0059ff",
    "editorLineNumber.foreground": "#6a6a6a",
    "editorLineNumber.activeForeground": "#0059ff",
    "editorGutter.addedBackground": "#008a00",
    "editorGutter.modifiedBackground": "#c27a00",
    "editorGutter.deletedBackground": "#d40000",
    "activityBar.background": "#ffffff",
    "sideBar.background": "#fafafa",
    "titleBar.activeBackground": "#ffffff",
    "statusBar.background": "#ffffff",
    "panel.background": "#fafafa",
    "terminal.background": "#ffffff",
    "button.background": "#0059ff",
    "button.foreground": "#ffffff",
    "focusBorder": "#0059ff"
  },
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "class": "#7b1fd0",
    "function": "#0059ff",
    "parameter": "#c26700",
    "property": "#006a7c",
    "variable.readonly": "#9b8700"
  },
  "tokenColors": [
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#707070", "fontStyle": "italic" }
    },
    {
      "name": "String",
      "scope": ["string"],
      "settings": { "foreground": "#008a00" }
    },
    {
      "name": "Keyword",
      "scope": ["keyword", "storage.type", "storage.modifier"],
      "settings": { "foreground": "#d40000" }
    }
  ]
}