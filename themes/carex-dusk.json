{
  "name": "Carex Dusk",
  "include": "./carex-dark.json",
  "type": "dark",
  "colors": {
    "editor.background": "#201c24",
    "editor.foreground": "#efe7ed",
    "editor.lineHighlightBackground": "#312a36",
    "editor.selectionBackground": "#725d6f66",
    "editorCursor.foreground": "#ffd2b3",
    "editorLineNumber.foreground": "#8a7a89",
    "editorLineNumber.activeForeground": "#e8a77b",
    "editorBracketHighlight.foreground1": "#8bb7ff",
    "editorBracketHighlight.foreground2": "#f29d7e",
    "editorBracketHighlight.foreground3": "#e9c46a",
    "editorBracketHighlight.foreground4": "#c8a2ff",
    "sideBar.background": "#1a171f",
    "activityBar.background": "#1a171f",
    "titleBar.activeBackground": "#1a171f",
    "statusBar.background": "#1a171f",
    "panel.background": "#1a171f",
    "terminal.background": "#1a171f",
    "button.background": "#e8a77b",
    "button.foreground": "#201c24",
    "focusBorder": "#e8a77b"
  },
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "class": "#c8a2ff",
    "function": "#8bb7ff",
    "parameter": "#e8a77b",
    "property": "#d8c0a8",
    "variable.readonly": "#e9c46a"
  },
  "tokenColors": [
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#8a7a89", "fontStyle": "italic" }
    },
    {
      "name": "String",
      "scope": ["string"],
      "settings": { "foreground": "#a9d3b3" }
    },
    {
      "name": "Number",
      "scope": ["constant.numeric", "constant"],
      "settings": { "foreground": "#e9c46a" }
    },
    {
      "name": "Keyword",
      "scope": ["keyword", "storage.type", "storage.modifier"],
      "settings": { "foreground": "#f29d7e" }
    },
    {
      "name": "Function",
      "scope": ["entity.name.function", "support.function"],
      "settings": { "foreground": "#8bb7ff" }
    },
    {
      "name": "Class",
      "scope": ["entity.name.class", "entity.name.type", "support.class"],
      "settings": { "foreground": "#c8a2ff" }
    }
  ]
}