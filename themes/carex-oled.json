{
  "name": "Carex OLED",
  "include": "./carex-dark.json",
  "type": "dark",
  "colors": {
    "editor.background": "#050505",
    "editor.foreground": "#d9def9",
    "editor.lineHighlightBackground": "#121217",
    "editor.selectionBackground": "#2f344d80",
    "editorCursor.foreground": "#f5e0dc",
    "editorLineNumber.foreground": "#5c6076",
    "editorLineNumber.activeForeground": "#89b4fa",
    "sideBar.background": "#08080a",
    "activityBar.background": "#08080a",
    "activityBar.foreground": "#89b4fa",
    "titleBar.activeBackground": "#08080a",
    "statusBar.background": "#08080a",
    "panel.background": "#08080a",
    "tab.activeBackground": "#050505",
    "tab.inactiveBackground": "#08080a",
    "terminal.background": "#050505",
    "editorStickyScroll.background": "#08080a",
    "focusBorder": "#89b4fa"
  },
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "class": "#cba6f7",
    "function": "#89b4fa",
    "parameter": "#fab387",
    "property": "#94e2d5",
    "variable.readonly": "#f9e2af"
  },
  "tokenColors": [
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#636a80", "fontStyle": "italic" }
    },
    {
      "name": "String",
      "scope": ["string"],
      "settings": { "foreground": "#a6e3a1" }
    },
    {
      "name": "Keyword",
      "scope": ["keyword", "storage.type", "storage.modifier"],
      "settings": { "foreground": "#f38ba8" }
    }
  ]
}