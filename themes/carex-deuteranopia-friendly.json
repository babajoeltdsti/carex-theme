{
  "name": "Carex Deuteranopia Friendly",
  "include": "./carex-dark.json",
  "type": "dark",
  "colors": {
    "editor.background": "#111827",
    "editor.foreground": "#e5eef9",
    "editor.lineHighlightBackground": "#1b2538",
    "editor.selectionBackground": "#38507d66",
    "editorCursor.foreground": "#ffcb77",
    "editorLineNumber.foreground": "#7181a3",
    "editorLineNumber.activeForeground": "#6ec5ff",
    "activityBar.background": "#0d1422",
    "sideBar.background": "#0d1422",
    "statusBar.background": "#0d1422",
    "panel.background": "#0d1422",
    "terminal.background": "#0d1422",
    "focusBorder": "#6ec5ff"
  },
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "class": "#c792ea",
    "function": "#6ec5ff",
    "parameter": "#ffcb77",
    "property": "#8be9fd",
    "variable.readonly": "#ffd166"
  },
  "tokenColors": [
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#7a89a8", "fontStyle": "italic" }
    },
    {
      "name": "String",
      "scope": ["string"],
      "settings": { "foreground": "#8be9fd" }
    },
    {
      "name": "Keyword",
      "scope": ["keyword", "storage.type", "storage.modifier"],
      "settings": { "foreground": "#f78c6c" }
    },
    {
      "name": "Function",
      "scope": ["entity.name.function", "support.function"],
      "settings": { "foreground": "#6ec5ff" }
    }
  ]
}