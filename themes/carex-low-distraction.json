{
  "name": "Carex Low Distraction",
  "include": "./carex-dark.json",
  "type": "dark",
  "colors": {
    "editor.background": "#1a1d27",
    "editor.foreground": "#c5cade",
    "editor.lineHighlightBackground": "#232838",
    "editor.selectionBackground": "#434a6455",
    "editorCursor.foreground": "#aab8ff",
    "editorLineNumber.foreground": "#5f667d",
    "editorLineNumber.activeForeground": "#9ea8cf",
    "editorWhitespace.foreground": "#303647",
    "activityBar.background": "#171a23",
    "sideBar.background": "#171a23",
    "titleBar.activeBackground": "#171a23",
    "statusBar.background": "#171a23",
    "panel.background": "#171a23",
    "terminal.background": "#171a23",
    "focusBorder": "#7f8bb3"
  },
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "class": "#b6b0d8",
    "function": "#9bb0e8",
    "parameter": "#c7a98d",
    "property": "#a9bfcb",
    "variable.readonly": "#d2c9a5"
  },
  "tokenColors": [
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#72798e", "fontStyle": "italic" }
    },
    {
      "name": "String",
      "scope": ["string"],
      "settings": { "foreground": "#9fc4a5" }
    },
    {
      "name": "Keyword",
      "scope": ["keyword", "storage.type", "storage.modifier"],
      "settings": { "foreground": "#d29aa6" }
    },
    {
      "name": "Function",
      "scope": ["entity.name.function", "support.function"],
      "settings": { "foreground": "#9bb0e8" }
    }
  ]
}