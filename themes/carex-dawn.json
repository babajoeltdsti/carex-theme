{
  "name": "Carex Dawn",
  "include": "./carex-light.json",
  "type": "light",
  "colors": {
    "editor.background": "#f7f1e8",
    "editor.foreground": "#5e544e",
    "editor.lineHighlightBackground": "#efe7db",
    "editor.selectionBackground": "#d5c7b680",
    "editorCursor.foreground": "#c97c5d",
    "editorLineNumber.foreground": "#b5a699",
    "editorLineNumber.activeForeground": "#b66d46",
    "sideBar.background": "#f2eadf",
    "activityBar.background": "#f2eadf",
    "titleBar.activeBackground": "#f2eadf",
    "statusBar.background": "#f2eadf",
    "panel.background": "#f2eadf",
    "terminal.background": "#f2eadf",
    "button.background": "#b66d46",
    "button.foreground": "#fff8ef",
    "focusBorder": "#b66d46"
  },
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "class": "#8d59d4",
    "function": "#356ad8",
    "parameter": "#c97c5d",
    "property": "#2d8a8f",
    "variable.readonly": "#bf8b2e"
  },
  "tokenColors": [
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#aa9d92", "fontStyle": "italic" }
    },
    {
      "name": "String",
      "scope": ["string"],
      "settings": { "foreground": "#4e8b50" }
    },
    {
      "name": "Number",
      "scope": ["constant.numeric", "constant"],
      "settings": { "foreground": "#bf8b2e" }
    },
    {
      "name": "Keyword",
      "scope": ["keyword", "storage.type", "storage.modifier"],
      "settings": { "foreground": "#c4515a" }
    }
  ]
}