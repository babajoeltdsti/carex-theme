{
  "name": "Carex Neon",
  "include": "./carex-dark.json",
  "type": "dark",
  "colors": {
    "editor.background": "#0b1020",
    "editor.foreground": "#eaf2ff",
    "editor.lineHighlightBackground": "#151c33",
    "editor.selectionBackground": "#2a3f7a70",
    "editorCursor.foreground": "#7df9ff",
    "editorLineNumber.foreground": "#5d6f9a",
    "editorLineNumber.activeForeground": "#7df9ff",
    "editorBracketHighlight.foreground1": "#7df9ff",
    "editorBracketHighlight.foreground2": "#ff4fd8",
    "editorBracketHighlight.foreground3": "#d6ff6b",
    "editorBracketHighlight.foreground4": "#ffb86c",
    "activityBar.background": "#08101d",
    "sideBar.background": "#08101d",
    "titleBar.activeBackground": "#08101d",
    "statusBar.background": "#08101d",
    "panel.background": "#08101d",
    "terminal.background": "#08101d",
    "button.background": "#7df9ff",
    "button.foreground": "#08101d",
    "focusBorder": "#7df9ff"
  },
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "class": "#ff4fd8",
    "function": "#7df9ff",
    "parameter": "#ffb86c",
    "property": "#d6ff6b",
    "variable.readonly": "#ffea7a"
  },
  "tokenColors": [
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#6a78a4", "fontStyle": "italic" }
    },
    {
      "name": "String",
      "scope": ["string"],
      "settings": { "foreground": "#d6ff6b" }
    },
    {
      "name": "Keyword",
      "scope": ["keyword", "storage.type", "storage.modifier"],
      "settings": { "foreground": "#ff4fd8" }
    },
    {
      "name": "Function",
      "scope": ["entity.name.function", "support.function"],
      "settings": { "foreground": "#7df9ff" }
    }
  ]
}