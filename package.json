{
  "name": "carex-theme",
  "displayName": "Carex",
  "description": "🎨 A premium VS Code theme suite with 11 color variants, file icons, and product icons. Inspired by Catppuccin, refined for long coding sessions.",
  "version": "2.0.0",
  "publisher": "OMERBABACO",
  "author": {
    "name": "Carex Theme Team"
  },
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Themes"
  ],
  "keywords": [
    "theme",
    "dark theme",
    "light theme",
    "high contrast",
    "oled",
    "neon",
    "dusk",
    "dawn",
    "dark",
    "light",
    "carex",
    "icon theme",
    "product icon theme",
    "color theme",
    "syntax highlighting",
    "modern",
    "catppuccin",
    "pastel colors",
    "soft colors",
    "eye friendly",
    "comfortable",
    "bracket colorization",
    "accessibility",
    "javascript",
    "typescript",
    "python",
    "react",
    "vue",
    "angular",
    "node"
  ],
  "galleryBanner": {
    "color": "#0a0a14",
    "theme": "dark"
  },
  "icon": "icon.png",
  "contributes": {
    "themes": [
      {
        "label": "Carex Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/carex-dark.json"
      },
      {
        "label": "Carex Light",
        "uiTheme": "vs",
        "path": "./themes/carex-light.json"
      },
      {
        "label": "Carex High Contrast Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/carex-high-contrast.json"
      },
      {
        "label": "Carex High Contrast Light",
        "uiTheme": "vs",
        "path": "./themes/carex-high-contrast-light.json"
      },
      {
        "label": "Carex OLED",
        "uiTheme": "vs-dark",
        "path": "./themes/carex-oled.json"
      },
      {
        "label": "Carex Dusk",
        "uiTheme": "vs-dark",
        "path": "./themes/carex-dusk.json"
      },
      {
        "label": "Carex Dawn",
        "uiTheme": "vs",
        "path": "./themes/carex-dawn.json"
      },
      {
        "label": "Carex Neon",
        "uiTheme": "vs-dark",
        "path": "./themes/carex-neon.json"
      },
      {
        "label": "Carex Deuteranopia Friendly",
        "uiTheme": "vs-dark",
        "path": "./themes/carex-deuteranopia-friendly.json"
      },
      {
        "label": "Carex Protanopia Friendly",
        "uiTheme": "vs-dark",
        "path": "./themes/carex-protanopia-friendly.json"
      },
      {
        "label": "Carex Low Distraction",
        "uiTheme": "vs-dark",
        "path": "./themes/carex-low-distraction.json"
      }
    ],
    "iconThemes": [
      {
        "id": "carex-file-icons",
        "label": "Carex File Icons",
        "path": "./fileicons/carex-file-icon-theme.json"
      }
    ],
    "productIconThemes": [
      {
        "id": "carex-product-icons",
        "label": "Carex Product Icons",
        "path": "./producticons/carex-product-icon-theme.json"
      }
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/babajoeltdsti/carex-theme"
  },
  "bugs": {
    "url": "https://github.com/babajoeltdsti/carex-theme/issues"
  },
  "homepage": "https://github.com/babajoeltdsti/carex-theme#readme",
  "license": "MIT",
  "scripts": {
    "build:product-icons": "fantasticon producticons/svg -o producticons/fonts -n carex-product-icons -t woff -g json",
    "package": "npm run build:product-icons && vsce package",
    "publish": "npm run build:product-icons && vsce publish"
  },
  "devDependencies": {
    "@vscode/vsce": "^2.19.0",
    "fantasticon": "^4.1.0"
  }
}
